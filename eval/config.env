# FineType Evaluation — dataset paths and configuration
# =====================================================
# Source this file before running eval scripts/SQL.
# Override any variable by exporting it before sourcing.
#
# Usage:
#   source eval/config.env        # from repo root
#   make eval-1m                  # Makefile sources automatically
#
# All paths default to ~/datasets/ — override for custom locations.

# GitTables 1M corpus (topics/ subdirectory has parquet files)
export GITTABLES_DIR="${GITTABLES_DIR:-${HOME}/datasets/gittables}"

# GitTables eval output (generated metadata, catalog, column_values)
export EVAL_OUTPUT="${EVAL_OUTPUT:-${GITTABLES_DIR}/eval_output}"

# SOTAB CTA data (validation/ and test/ subdirectories)
export SOTAB_DIR="${SOTAB_DIR:-${HOME}/datasets/sotab/cta}"

# DuckDB extension path (relative to repo root)
export EXTENSION_PATH="${EXTENSION_PATH:-$(pwd)/target/release/finetype_duckdb.duckdb_extension}"

# Python venv for eval scripts (pyarrow, pandas)
export EVAL_VENV="${EVAL_VENV:-${HOME}/.venvs/finetype-eval}"
